{
  "kind": "collectionType",
  "collectionName": "post_stats",
  "info": {
    "singularName": "post-stat",
    "pluralName": "post-stats",
    "displayName": "Post Stat"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "likeCount": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "blog_post": {
      "type": "relation",
